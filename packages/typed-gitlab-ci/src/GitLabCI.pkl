/// GitLab CI Pipeline Configuration
///
/// Amend this module to define a type-safe GitLab CI pipeline.
///
/// Example:
///   amends "../src/GitLabCI.pkl"
///   stages { "build"; "test" }
///   jobs { ["build"] { stage = "build"; script { "make build" } } }
module typed.gitlab.ci.GitLabCI

import "Job.pkl"
import "Variable.pkl"
import "Include.pkl"
import "Cache.pkl"
import "Artifact.pkl"

output {
  renderer = new YamlRenderer {
    omitNullProperties = true
  }
}

/// Global variables
variables: Mapping<String, String|Variable>? = null

/// Pipeline stages (ordered)
stages: Listing<String>? = null

/// Default settings for all jobs
default: DefaultSettings? = null

/// Include external configurations
include: Listing<Include>? = null

/// Jobs defined in this pipeline
jobs: Mapping<String, Job>

/// Workflow configuration
workflow: WorkflowConfig? = null

/// Global image
image: (String|Job.ImageConfig)? = null

/// Global services
services: Listing<String|Job.ServiceConfig>? = null

/// Global before_script
before_script: Listing<String>? = null

/// Global after_script
after_script: Listing<String>? = null

/// Global cache
cache: (Cache|Listing<Cache>)? = null

/// Global retry
retry: (Int|Job.RetryConfig)? = null

/// Global timeout
timeout: String? = null

/// Global interruptible
interruptible: Boolean? = null

/// Global tags
tags: Listing<String>? = null

/// Validates that all job stage references exist in the stages list
hidden stagesValid: Boolean = 
  stages == null || 
  jobs.values.every((job) -> 
    job.stage == null || stages.contains(job.stage)
  )

/// Constraint: Enforce stage references
local `_validateStages` = if (!stagesValid) throw("""
  Pipeline validation failed: One or more jobs reference stages not defined in the 'stages' list.
  
  Defined stages: \(stages)
  
  Fix: Ensure every job's 'stage' value is listed in the pipeline's 'stages'.
  """) else true

/// Validates that all job needs references exist
hidden needsValid: Boolean =
  jobs.values.every((job) ->
    job.needs == null ||
    job.needs.every((need) ->
      need is String && jobs.containsKey(need) ||
      need is Job.NeedConfig && (need.project != null || jobs.containsKey(need.job))
    )
  )

/// Constraint: Enforce needs references
local `_validateNeeds` = if (!needsValid) throw("""
  Pipeline validation failed: One or more jobs reference non-existent jobs in 'needs'.
  
  Available jobs: \(jobs.keys)
  
  Fix: Ensure every job name in 'needs' exists in the pipeline, or uses 'project' for cross-project dependencies.
  """) else true

/// Default settings for all jobs
class DefaultSettings {
  /// Default image
  image: String|Job.ImageConfig?
  
  /// Default services
  services: Listing<String|Job.ServiceConfig>?
  
  /// Default before_script
  before_script: Listing<String>?
  
  /// Default after_script
  after_script: Listing<String>?
  
  /// Default cache
  cache: Cache|Listing<Cache>?
  
  /// Default retry
  retry: Int|Job.RetryConfig?
  
  /// Default timeout
  timeout: String?
  
  /// Default interruptible
  interruptible: Boolean?
  
  /// Default tags
  tags: Listing<String>?
  
  /// Default artifacts
  artifacts: Artifact?
}

/// Workflow configuration
class WorkflowConfig {
  /// Rules for the entire pipeline
  rules: Listing<WorkflowRule>?
  
  /// Pipeline name
  name: String?
  
  /// Auto-cancel configuration
  auto_cancel: AutoCancelConfig?
}

/// Auto-cancel configuration for pipelines
class AutoCancelConfig {
  /// Cancel behavior on new commits
  on_new_commit: ("conservative"|"interruptible"|"none")?
  
  /// Cancel behavior on new push
  on_job_failure: ("all"|"none")?
}

/// Workflow rule
class WorkflowRule {
  /// Condition expression
  `if`: String?
  
  /// Changes to files
  changes: Listing<String>?
  
  /// When to run
  `when`: ("always"|"never")?
  
  /// Variables to set
  variables: Mapping<String, String|Variable>?
}
